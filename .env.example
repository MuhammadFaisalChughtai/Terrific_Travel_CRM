# ──────────────────────────────────────────────────────────────────────────────
# Terrific Travel TMS — Environment Configuration
# Copy to .env for local dev, or .env.production for production.
# ──────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
POSTGRES_USER=tms_user
POSTGRES_PASSWORD=tms_password
POSTGRES_DB=tms_db
DATABASE_URL=postgresql://tms_user:tms_password@postgres:5432/tms_db?schema=public

# Caching (Redis)
REDIS_HOST=redis
REDIS_PORT=6379

# Messaging (RabbitMQ)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Object Storage (MinIO)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
# Public-facing MinIO URL (rewritten into image/file URLs served to the browser)
# Dev:  http://localhost:9000
# Prod: https://cdn.terrifictravel.co.uk
MINIO_PUBLIC_URL=http://localhost:9000

# Authentication (JWT)
JWT_ACCESS_SECRET=tms_super_secret_access_key_987654321
JWT_REFRESH_SECRET=tms_super_secret_refresh_key_123456789
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Currency Setting
CURRENCY=GBP
CURRENCY_SYMBOL=£

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=terrifictravelltd@gmail.com
SMTP_PASSWORD="tfvu lzie vefj uhar"
SMTP_FROM="no-reply@terrifictravel.co.uk"

# Application URLs
# Dev:  http://localhost:5173        | Prod: https://crm.terrifictravel.co.uk
FRONTEND_URL=http://localhost:5173
# Dev:  http://localhost:3000        | Prod: https://api.terrifictravel.co.uk
BACKEND_URL=http://localhost:3000

# Useful commands:
# docker exec tms-backend npx prisma db push --schema=apps/backend/prisma/schema.prisma --accept-data-loss
# Production deploy: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d